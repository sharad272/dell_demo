DB_TYPE=sqlserver
DB_HOST=your-sqlserver-host
DB_PORT=1433
DB_USERNAME=DOMAIN\\username
DB_PASSWORD=your-password
DB_DATABASE=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_JDBC_URL=jdbc:sqlserver://your-sqlserver-host:1433
DB_JDBC_DRIVER=com.microsoft.sqlserver.jdbc.SQLServerDriver

HF_MODEL_ID=openai/gpt-oss-20b
HUGGINGFACEHUB_API_TOKEN=your-hf-token

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=sentence-transformers/all-mpnet-base-v2
HYBRID_CANDIDATE_MULTIPLIER=6
RRF_K=60
RERANKER_CANDIDATE_MULTIPLIER=4

VECTOR_DB_DIR=./faiss_index
MAX_SQL_ROWS=200

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=test
